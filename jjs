-- Função segura para trocar tema
local function SafeTheme(themeName)
    local success, err = pcall(function()
        Rayfield:SetTheme(themeName)
    end)
    if not success then
        warn("LUPOS: Erro ao aplicar tema " .. themeName .. ": " .. tostring(err))
    end
end

SettingsTab:CreateButton({
   Name = "Amber Theme",
   Callback = function()
      SafeTheme("Amber")
   end,
})

SettingsTab:CreateButton({
   Name = "Purple Theme",
   Callback = function()
      SafeTheme("Purple")
   end,
})

SettingsTab:CreateButton({
   Name = "Ocean Theme",
   Callback = function()
      SafeTheme("Ocean")
   end,
})

-- Lógica Otimizada Anti-Lag
task.spawn(function()
    while true do
        if StalkEnabled then
            local playersList = Players:GetPlayers()
            local myChar = LocalPlayer.Character
            
            if myChar and myChar:FindFirstChild("HumanoidRootPart") then
                for i = 1, #playersList do
                    if not StalkEnabled then break end
                    
                    local targetPlayer = playersList[i]
                    if targetPlayer ~= LocalPlayer then
                        local char = targetPlayer.Character
                        if char then
                            local root = char:FindFirstChild("HumanoidRootPart")
                            local hum = char:FindFirstChildOfClass("Humanoid")
                            
                            if root and hum and hum.Health > 0 then
                                myChar:PivotTo(root.CFrame * CFrame.new(0, 0, StalkDistance))
                                if TP_Delay > 0 then task.wait(TP_Delay) end
                            end
                        end
                    end
                end
            end
        else
            task.wait(0.3)
        end
        RunService.Heartbeat:Wait()
    end
end)

-- Tenta forçar o Amber após um pequeno delay para evitar erro de carregamento
task.delay(1, function()
    SafeTheme("Amber")
end)

