local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- Configurações e Cache
local StalkEnabled = false
local StalkDistance = 3.5 
local TP_Delay = 0.05 

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

-- Janela Principal com Sistema de Key e TEMA ROXO
local Window = Rayfield:CreateWindow({
   Name = "LUPOS | v0.2",
   LoadingTitle = "LUPOS SYSTEMS",
   LoadingSubtitle = "by Lupos",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "LuposScripts",
      FileName = "Gojo_02"
   },
   KeySystem = true,
   KeySettings = {
      Title = "Lupos Systems | Key",
      Subtitle = "Sistema de Autenticação",
      Note = "Chave: LUPOS_FREE_2026",
      FileName = "LuposKey", 
      SaveKey = true, 
      GrabKeyFromSite = false,
      Key = {"LUPOS_FREE_2026", "GOJO_TOP_TIER"}
   }
})

-- ESTA LINHA MUDA A COR DA GUI
Rayfield:SetTheme("Purple") 

-- Aba de Combate
local MainTab = Window:CreateTab("Main", 4483362458)

-- Interface de Usuário
MainTab:CreateSection("Stalker Configuration")

MainTab:CreateToggle({
   Name = "Global Hyper-Stalker",
   CurrentValue = false,
   Flag = "StalkToggle",
   Callback = function(Value)
      StalkEnabled = Value
   end,
})

MainTab:CreateSlider({
   Name = "Distance (Studs)",
   Range = {1, 15},
   Increment = 0.5,
   Suffix = " studs",
   CurrentValue = 3.5,
   Flag = "DistSlider",
   Callback = function(Value)
      StalkDistance = Value
   end,
})

MainTab:CreateSlider({
   Name = "TP Delay / Lag Fix",
   Range = {0, 0.5},
   Increment = 0.01,
   Suffix = "s",
   CurrentValue = 0.05,
   Flag = "DelaySlider",
   Callback = function(Value)
      TP_Delay = Value
   end,
})

-- Lógica Otimizada Anti-Lag
task.spawn(function()
    while true do
        if StalkEnabled then
            local playersList = Players:GetPlayers()
            local myChar = LocalPlayer.Character
            
            if myChar and myChar:FindFirstChild("HumanoidRootPart") then
                for i = 1, #playersList do
                    if not StalkEnabled then break end
                    
                    local targetPlayer = playersList[i]
                    if targetPlayer ~= LocalPlayer then
                        local char = targetPlayer.Character
                        if char then
                            local root = char:FindFirstChild("HumanoidRootPart")
                            local hum = char:FindFirstChildOfClass("Humanoid")
                            
                            if root and hum and hum.Health > 0 then
                                myChar:PivotTo(root.CFrame * CFrame.new(0, 0, StalkDistance))
                                if TP_Delay > 0 then task.wait(TP_Delay) end
                            end
                        end
                    end
                end
            end
        else
            task.wait(0.3)
        end
        RunService.Heartbeat:Wait()
    end
end)

Rayfield:Notify({
   Title = "LUPOS SYSTEMS",
   Content = "Gojo 0.2 (Purple Edition) Loaded!",
   Duration = 4,
   Image = 4483362458,
})
