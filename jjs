local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- Configurações Iniciais
local StalkEnabled = false
local StalkDistance = 3.5 
local TP_Delay = 0.05 

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

-- Janela Principal
local Window = Rayfield:CreateWindow({
   Name = "DFX Hyper-Stalker | All-Players Edition",
   LoadingTitle = "DFX Systems",
   LoadingSubtitle = "by Gemini",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "DFX_Stalker", 
      FileName = "Config"
   },
   Discord = {
      Enabled = false,
      Invite = "", 
      RememberJoins = true 
   },
   KeySystem = false 
})

-- Tab Principal
local MainTab = Window:CreateTab("Main Loop", 4483362458) -- Ícone de alvo

-- Toggle de Ativação
local Toggle = MainTab:CreateToggle({
   Name = "Enable Global Stalking",
   CurrentValue = false,
   Flag = "StalkToggle",
   Callback = function(Value)
      StalkEnabled = Value
   end,
})

-- Slider de Distância
MainTab:CreateSlider({
   Name = "Stalk Distance",
   Range = {1, 15},
   Increment = 0.5,
   Suffix = " Studs",
   CurrentValue = 3.5,
   Flag = "DistanceSlider",
   Callback = function(Value)
      StalkDistance = Value
   end,
})

-- Slider de Delay (Velocidade do Ciclo)
MainTab:CreateSlider({
   Name = "TP Delay (Hit Reg)",
   Range = {0, 0.5},
   Increment = 0.01,
   Suffix = " sec",
   CurrentValue = 0.05,
   Flag = "DelaySlider",
   Callback = function(Value)
      TP_Delay = Value
   end,
})

-- Seção de Créditos/Info
local InfoSection = MainTab:CreateSection("Status")
local StatusLabel = MainTab:CreateLabel("Targeting: Cycling Server Players")

-- Lógica Principal (Loop de Stalking)
task.spawn(function()
    while true do
        if StalkEnabled then
            local allPlayers = Players:GetPlayers()
            
            for _, targetPlayer in ipairs(allPlayers) do
                if not StalkEnabled then break end -- Para instantaneamente se desligar o toggle

                if targetPlayer ~= LocalPlayer and targetPlayer.Character then
                    local character = targetPlayer.Character
                    local root = character:FindFirstChild("HumanoidRootPart")
                    local hum = character:FindFirstChildOfClass("Humanoid")
                    
                    if root and hum and hum.Health > 0 then
                        local myChar = LocalPlayer.Character
                        if myChar and myChar:FindFirstChild("HumanoidRootPart") then
                            -- Executa o Teleporte
                            myChar:PivotTo(root.CFrame * CFrame.new(0, 0, StalkDistance))
                            task.wait(TP_Delay)
                        end
                    end
                end
            end
        end
        RunService.Heartbeat:Wait()
    end
end)

Rayfield:Notify({
   Title = "Script Loaded",
   Content = "DFX Hyper-Stalker V3 ready!",
   Duration = 5,
   Image = 4483362458,
   Actions = {
      Ignore = {
         Name = "Okay!",
         Callback = function() print("User acknowledged.") end
      },
   },
})
