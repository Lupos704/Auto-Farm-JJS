-- Função ESP (HIGHLIGHT)
local function ApplyHighlight(model)
    if model:IsA("Model") and not model:FindFirstChild("LuposESP") then
        local highlight = Instance.new("Highlight")
        highlight.Name = "LuposESP"
        highlight.Parent = model
        highlight.FillColor = Color3.fromRGB(170, 0, 255) -- Roxo Gojo
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255) -- Contorno Branco
        highlight.FillTransparency = 0.5
        highlight.OutlineTransparency = 0
    end
end

-- ========================================================
-- LÓGICA DO STALKER (IDÊNTICA À QUE FUNCIONOU - NÃO MEXER)
-- ========================================================
task.spawn(function()
    while true do
        if StalkEnabled then
            local playersList = Players:GetPlayers()
            local myChar = LocalPlayer.Character
            if myChar then
                for i = 1, #playersList do
                    local targetPlayer = playersList[i]
                    if targetPlayer ~= LocalPlayer and StalkEnabled then
                        local char = targetPlayer.Character
                        if char then
                            local root = char:FindFirstChild("HumanoidRootPart")
                            local hum = char:FindFirstChildOfClass("Humanoid")
                            if root and hum and hum.Health > 0 then
                                myChar:PivotTo(root.CFrame * CFrame.new(0, 0, StalkDistance))
                                if TP_Delay > 0 then task.wait(TP_Delay) end
                            end
                        end
                    end
                end
            end
        else
            task.wait(0.5)
        end
        RunService.Heartbeat:Wait()
    end
end)

