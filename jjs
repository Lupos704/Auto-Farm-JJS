local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Gojo-0.2 | ESTÁVEL",
   LoadingTitle = "Gojo-0.2 By LUPOS",
   LoadingSubtitle = "Créditos: Lupos",
   ConfigurationSaving = {Enabled = false}
})

local Tab = Window:CreateTab("Principal", 4483362458)

local tpEnabled = false
local tpDelay = 0.1 -- Aumentado levemente para estabilidade
local loopId = 0

Tab:CreateSection("Anti-Rubber Band Edition")

local function safeTeleport(targetPart)
    local lp = game.Players.LocalPlayer
    local char = lp.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    
    if hrp and targetPart then
        -- 1. Zera a física para o servidor não se confundir
        hrp.Velocity = Vector3.new(0,0,0)
        hrp.RotVelocity = Vector3.new(0,0,0)
        
        -- 2. Teleporta com um pequeno offset para cima e para frente
        local newPos = targetPart.CFrame * CFrame.new(0, 0, -2.5)
        hrp.CFrame = newPos
        
        -- 3. "Ancoragem" Relâmpago: Força o servidor a registrar a posição
        -- Isso é o que evita o teleporte falso
        hrp.Anchored = true
        task.wait(0.01)
        hrp.Anchored = false
    end
end

local Toggle = Tab:CreateToggle({
   Name = "Ativar Turbo TP",
   CurrentValue = false,
   Flag = "TurboToggle",
   Callback = function(Value)
      tpEnabled = Value
      if tpEnabled then
         loopId = loopId + 1
         local current = loopId
         task.spawn(function()
            while tpEnabled and current == loopId do
               local players = game.Players:GetPlayers()
               for _, target in pairs(players) do
                  if not tpEnabled or current ~= loopId then break end
                  if target ~= game.Players.LocalPlayer and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                     safeTeleport(target.Character.HumanoidRootPart)
                     task.wait(tpDelay)
                  end
               end
               task.wait(0.1)
            end
         end)
      end
   end,
})

Tab:CreateKeybind({
   Name = "Atalho: Tecla (E)",
   CurrentKeybind = "E",
   Callback = function()
      Toggle:Set(not tpEnabled)
   end,
})

Tab:CreateSlider({
   Name = "Delay de Segurança",
   Range = {0.05, 1},
   Increment = 0.05,
   Suffix = "s",
   CurrentValue = 0.1,
   Callback = function(Value)
      tpDelay = Value
   end,
})
