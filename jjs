-- FUNÇÃO ESP (HIGHLIGHT)
local function ApplyESP(model)
    if not model:FindFirstChild("LuposESP") then
        local highlight = Instance.new("Highlight")
        highlight.Name = "LuposESP"
        highlight.Parent = model
        highlight.FillColor = Color3.fromRGB(170, 0, 255) -- Roxo Gojo
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        highlight.FillTransparency = 0.5
    end
end

-- LÓGICA DO STALKER (IDÊNTICA À QUE FUNCIONOU)
task.spawn(function()
    while true do
        if StalkEnabled then
            local playersList = Players:GetPlayers()
            local myChar = LocalPlayer.Character
            if myChar then
                for i = 1, #playersList do
                    local targetPlayer = playersList[i]
                    if targetPlayer ~= LocalPlayer and StalkEnabled then
                        local char = targetPlayer.Character
                        if char then
                            local root = char:FindFirstChild("HumanoidRootPart")
                            local hum = char:FindFirstChildOfClass("Humanoid")
                            if root and hum and hum.Health > 0 then
                                myChar:PivotTo(root.CFrame * CFrame.new(0, 0, StalkDistance))
                                if TP_Delay > 0 then task.wait(TP_Delay) end
                            end
                        end
                    end
                end
            end
        else
            task.wait(0.5)
        end
        RunService.Heartbeat:Wait()
    end
end)

-- LÓGICA DO ESP (RODA SEPARADO PARA NÃO TRAVAR O STALKER)
task.spawn(function()
    while true do
        if ESPEnabled then
            -- Procura Dummies no Workspace (apenas Models com Humanoid que não são Players)
            for _, obj in ipairs(workspace:GetChildren()) do
                if obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid") then
                    if not Players:GetPlayerFromCharacter(obj) then
                        ApplyESP(obj)
                    end
                end
            end
        end
        task.wait(2) -- Só checa novos dummies a cada 2 segundos (MUITO LEVE)
    end
end)

