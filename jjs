local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- Configurações e Cache
local StalkEnabled = false
local GhostEnabled = false
local StalkDistance = 3.5 
local TP_Delay = 0.05 

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

-- Janela Principal
local Window = Rayfield:CreateWindow({
   Name = "LUPOS | v0.2",
   LoadingTitle = "LUPOS SYSTEMS",
   LoadingSubtitle = "Infinity Void Initializing...",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "LuposScripts",
      FileName = "Gojo_02"
   },
   KeySystem = false 
})

-- TAB 1: COMBAT (O Stalker que você já tem)
local CombatTab = Window:CreateTab("Combat", 4483362458)

CombatTab:CreateSection("Stalker Configuration")

CombatTab:CreateToggle({
   Name = "Global Hyper-Stalker",
   CurrentValue = false,
   Flag = "StalkToggle",
   Callback = function(Value)
      StalkEnabled = Value
   end,
})

CombatTab:CreateSlider({
   Name = "Distance (Studs)",
   Range = {1, 15},
   Increment = 0.5,
   Suffix = " studs",
   CurrentValue = 3.5,
   Flag = "DistSlider",
   Callback = function(Value)
      StalkDistance = Value
   end,
})

CombatTab:CreateSlider({
   Name = "TP Delay / Lag Fix",
   Range = {0, 0.5},
   Increment = 0.01,
   Suffix = "s",
   CurrentValue = 0.05,
   Flag = "DelaySlider",
   Callback = function(Value)
      TP_Delay = Value
   end,
})

-- TAB 2: GHOST (Invisibilidade e Extras)
local GhostTab = Window:CreateTab("Ghost", 4483472135) -- Ícone de fantasma

GhostTab:CreateSection("Stealth Modules")

GhostTab:CreateToggle({
   Name = "Invisibility (Transparency)",
   CurrentValue = false,
   Flag = "InvisToggle",
   Callback = function(Value)
      GhostEnabled = Value
      
      -- Função para aplicar transparência
      local function ApplyGhost(character)
          for _, part in ipairs(character:GetDescendants()) do
              if part:IsA("BasePart") or part:IsA("Decal") then
                  part.Transparency = Value and 1 or 0
                  if part:IsA("BasePart") then
                      part.CastShadow = not Value
                  end
              end
          end
      end

      if LocalPlayer.Character then
          ApplyGhost(LocalPlayer.Character)
      end
   end,
})

GhostTab:CreateButton({
   Name = "Force Reset Appearance",
   Callback = function()
      local char = LocalPlayer.Character
      if char then
          for _, part in ipairs(char:GetDescendants()) do
              if part:IsA("BasePart") or part:IsA("Decal") then
                  part.Transparency = 0
              end
          end
      end
   end,
})

-- LÓGICA PRINCIPAL (Loop Otimizado)
task.spawn(function()
    while true do
        -- Loop do Stalker
        if StalkEnabled then
            local playersList = Players:GetPlayers()
            local myChar = LocalPlayer.Character
            
            if myChar and myChar:FindFirstChild("HumanoidRootPart") then
                for i = 1, #playersList do
                    if not StalkEnabled then break end
                    
                    local targetPlayer = playersList[i]
                    if targetPlayer ~= LocalPlayer then
                        local char = targetPlayer.Character
                        if char then
                            local root = char:FindFirstChild("HumanoidRootPart")
                            local hum = char:FindFirstChildOfClass("Humanoid")
                            
                            if root and hum and hum.Health > 0 then
                                myChar:PivotTo(root.CFrame * CFrame.new(0, 0, StalkDistance))
                                if TP_Delay > 0 then task.wait(TP_Delay) end
                            end
                        end
                    end
                end
            end
        end

        -- Mantém invisível mesmo se o jogo tentar resetar (se o toggle estiver ativo)
        if GhostEnabled then
            local myChar = LocalPlayer.Character
            if myChar then
                for _, part in ipairs(myChar:GetDescendants()) do
                    if (part:IsA("BasePart") or part:IsA("Decal")) and part.Transparency ~= 1 then
                        part.Transparency = 1
                    end
                end
            end
        end

        if not StalkEnabled and not GhostEnabled then
            task.wait(0.3) -- Economiza CPU se nada estiver ativo
        end
        RunService.Heartbeat:Wait()
    end
end)

Rayfield:Notify({
   Title = "LUPOS SYSTEMS",
   Content = "Gojo 0.2 | Ghost Tab Loaded",
   Duration = 4,
   Image = 4483362458,
})
