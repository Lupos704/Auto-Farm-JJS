-- 1. Função para marcar Dummies automaticamente (Roda apenas UMA vez)
-- Ela procura modelos que tenham um Humanoid e a palavra "Dummy" no nome.
-- Se o seu jogo usa outro nome, mude "Dummy" abaixo.
local function TagDummiesAutomatically()
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid") then
            if not Players:GetPlayerFromCharacter(obj) and string.find(obj.Name, "Dummy") then
                CollectionService:AddTag(obj, DUMMY_TAG)
            end
        end
    end
end

-- Roda a marcação em segundo plano para não dar mini-lag ao iniciar
task.spawn(TagDummiesAutomatically)

-- 2. Loop de verificação do ESP (Super leve, roda a cada 5s)
task.spawn(function()
    while true do
        if ESPEnabled then
            -- CollectionService acha todos os marcados instantaneamente
            for _, dummy in ipairs(CollectionService:GetTagged(DUMMY_TAG)) do
                pcall(function() -- Escudo contra erros se o dummy sumir
                    if dummy and dummy.Parent then
                        ApplyHighlight(dummy)
                    end
                end)
            end
        end
        task.wait(5) -- Checa novos dummies só a cada 5 segundos
    end
end)

