-- Função de ESP Ultra Leve
local function ApplyHighlight(char, color)
    if char and not char:FindFirstChild("LuposESP") then
        local highlight = Instance.new("Highlight")
        highlight.Name = "LuposESP"
        highlight.Parent = char
        highlight.FillColor = color
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        highlight.FillTransparency = 0.5
        highlight.Enabled = ESPEnabled
    end
end

-- Gerenciador de ESP (Sem loops pesados)
local function UpdateESP()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            ApplyHighlight(player.Character, Color3.fromRGB(0, 255, 255))
            if player.Character:FindFirstChild("LuposESP") then
                player.Character.LuposESP.Enabled = ESPEnabled
            end
        end
    end
    
    -- Procura Dummies apenas no Workspace raiz (mais rápido)
    for _, obj in ipairs(workspace:GetChildren()) do
        if obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid") and not Players:GetPlayerFromCharacter(obj) then
            ApplyHighlight(obj, Color3.fromRGB(255, 0, 255))
            if obj:FindFirstChild("LuposESP") then
                obj.LuposESP.Enabled = ESPEnabled
            end
        end
    end
end

-- Loop de Movimentação (Stalker) - Otimizado para 30 FPS de checagem
task.spawn(function()
    while true do
        if StalkEnabled then
            pcall(function()
                local myChar = LocalPlayer.Character
                if myChar and myChar:FindFirstChild("HumanoidRootPart") then
                    for _, player in ipairs(Players:GetPlayers()) do
                        if player ~= LocalPlayer and player.Character then
                            local root = player.Character:FindFirstChild("HumanoidRootPart")
                            if root and player.Character.Humanoid.Health > 0 then
                                myChar:PivotTo(root.CFrame * CFrame.new(0, 0, StalkDistance))
                                if TP_Delay > 0 then task.wait(TP_Delay) end
                            end
                        end
                    end
                end
            end)
        end
        task.wait(0.03) -- Trava o loop em ~30hz para não fritar a CPU
    end
end)

-- Loop de ESP (Apenas atualização de estado)
task.spawn(function()
    while true do
        if ESPEnabled then
            UpdateESP()
            task.wait(1) -- Atualiza novos bonecos a cada 1 segundo (muito mais leve)
        else
            -- Desativa o brilho sem deletar (mais rápido para o PC)
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj.Name == "LuposESP" and obj:IsA("Highlight") then
                    obj.Enabled = false
                end
            end
            task.wait(1)
        end
    end
end)

