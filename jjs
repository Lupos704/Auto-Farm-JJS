-- FUNÇÃO ESP OTIMIZADA
local function ApplyESP(object, color)
    if not object:FindFirstChild("LuposESP") then
        local highlight = Instance.new("Highlight")
        highlight.Name = "LuposESP"
        highlight.Parent = object
        highlight.FillColor = color
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        highlight.FillTransparency = 0.5
    end
end

-- LOOP DO STALKER (Separado para performance)
task.spawn(function()
    while task.wait() do
        if StalkEnabled then
            local myChar = LocalPlayer.Character
            if myChar and myChar:FindFirstChild("HumanoidRootPart") then
                for _, player in ipairs(Players:GetPlayers()) do
                    if not StalkEnabled then break end
                    if player ~= LocalPlayer and player.Character then
                        local root = player.Character:FindFirstChild("HumanoidRootPart")
                        local hum = player.Character:FindFirstChildOfClass("Humanoid")
                        if root and hum and hum.Health > 0 then
                            myChar:PivotTo(root.CFrame * CFrame.new(0, 0, StalkDistance))
                            if TP_Delay > 0 then task.wait(TP_Delay) end
                        end
                    end
                end
            end
        end
    end
end)

-- LOOP DO ESP (Otimizado: Checa Dummies raramente)
task.spawn(function()
    local lastDummyCheck = 0
    while task.wait(0.1) do -- Roda 10x por segundo em vez de 60x (muito mais leve)
        if ESPEnabled then
            -- Players (Leve)
            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character then
                    ApplyESP(player.Character, Color3.fromRGB(0, 255, 255))
                end
            end

            -- Dummies (Pesado - Só roda a cada 3 segundos)
            if tick() - lastDummyCheck > 3 then
                for _, obj in ipairs(workspace:GetChildren()) do -- GetChildren é 100x mais rápido que GetDescendants
                    if obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid") and not Players:GetPlayerFromCharacter(obj) then
                        ApplyESP(obj, Color3.fromRGB(255, 0, 255))
                    end
                end
                lastDummyCheck = tick()
            end
        else
            -- Limpeza eficiente
            for _, player in ipairs(Players:GetPlayers()) do
                if player.Character and player.Character:FindFirstChild("LuposESP") then
                    player.Character.LuposESP:Destroy()
                end
            end
            -- Procura e limpa Highlights órfãos no workspace de forma segura
            for _, obj in ipairs(workspace:GetChildren()) do
                if obj:FindFirstChild("LuposESP") then obj.LuposESP:Destroy() end
            end
        end
    end
end)
