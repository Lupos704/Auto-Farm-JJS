local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- Configurações e Variáveis de Cache
local StalkEnabled = false
local StalkDistance = 3.5 
local TP_Delay = 0.05 

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

-- Janela Principal (Com Sistema de Key Adicionado)
local Window = Rayfield:CreateWindow({
   Name = "Gojo 0.2 By: Lupos",
   LoadingTitle = "Infinity Void System",
   LoadingSubtitle = "By Lupos",
   ConfigurationSaving = {
      Enabled = false,
      FolderName = "GojoStalker"
   },
   KeySystem = true, -- ATIVADO
   KeySettings = {
      Title = "Lupos Systems | Key",
      Subtitle = "Autenticação Necessária",
      Note = "Chave: LUPOS_FREE_2026",
      FileName = "LuposKey_Final_V1", -- Nome novo para não ler chaves antigas
      SaveKey = false, -- NÃO SALVAR (Vai pedir sempre)
      GrabKeyFromSite = false,
      Key = {"LUPOS_FREE_2026", "GOJO_TOP_TIER"}
   }
})

-- Aba Principal
local MainTab = Window:CreateTab("Combat", 4483362458)

-- Toggle de Ativação
MainTab:CreateToggle({
   Name = "Stalker Mode (All Players)",
   CurrentValue = false,
   Flag = "StalkToggle",
   Callback = function(Value)
      StalkEnabled = Value
   end,
})

-- Slider de Distância
MainTab:CreateSlider({
   Name = "Distance Behind Target",
   Range = {1, 15},
   Increment = 0.5,
   Suffix = " Studs",
   CurrentValue = 3.5,
   Flag = "DistSlider",
   Callback = function(Value)
      StalkDistance = Value
   end,
})

-- Slider de Delay (Anti-Lag/Detection)
MainTab:CreateSlider({
   Name = "TP Delay (Performance)",
   Range = {0, 0.5},
   Increment = 0.01,
   Suffix = "s",
   CurrentValue = 0.05,
   Flag = "DelaySlider",
   Callback = function(Value)
      TP_Delay = Value
   end,
})

-- Lógica Otimizada (A que você confirmou que funciona)
task.spawn(function()
    while true do
        if StalkEnabled then
            local playersList = Players:GetPlayers()
            local myChar = LocalPlayer.Character
            
            if myChar then
                for i = 1, #playersList do
                    local targetPlayer = playersList[i]
                    
                    if targetPlayer ~= LocalPlayer and StalkEnabled then
                        local char = targetPlayer.Character
                        if char then
                            local root = char:FindFirstChild("HumanoidRootPart")
                            local hum = char:FindFirstChildOfClass("Humanoid")
                            
                            if root and hum and hum.Health > 0 then
                                myChar:PivotTo(root.CFrame * CFrame.new(0, 0, StalkDistance))
                                
                                if TP_Delay > 0 then
                                    task.wait(TP_Delay)
                                end
                            end
                        end
                    end
                end
            end
        else
            task.wait(0.5)
        end
        RunService.Heartbeat:Wait()
    end
end)

Rayfield:Notify({
   Title = "Gojo 0.2 Loaded",
   Content = "Script desenvolvido por Lupos.",
   Duration = 3,
   Image = 4483362458,
})
