-- Função para Criar o Highlight
local function ApplyESP(object, color)
    if not object:FindFirstChild("LuposESP") then
        local highlight = Instance.new("Highlight")
        highlight.Name = "LuposESP"
        highlight.Parent = object
        highlight.FillColor = color
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        highlight.FillTransparency = 0.5
        highlight.OutlineTransparency = 0
    end
end

-- Lógica Principal (Stalker + ESP)
task.spawn(function()
    while true do
        -- Lógica do STALKER
        if StalkEnabled then
            local playersList = Players:GetPlayers()
            local myChar = LocalPlayer.Character
            
            if myChar and myChar:FindFirstChild("HumanoidRootPart") then
                for i = 1, #playersList do
                    if not StalkEnabled then break end
                    local targetPlayer = playersList[i]
                    if targetPlayer ~= LocalPlayer then
                        local char = targetPlayer.Character
                        if char then
                            local root = char:FindFirstChild("HumanoidRootPart")
                            local hum = char:FindFirstChildOfClass("Humanoid")
                            if root and hum and hum.Health > 0 then
                                myChar:PivotTo(root.CFrame * CFrame.new(0, 0, StalkDistance))
                                if TP_Delay > 0 then task.wait(TP_Delay) end
                            end
                        end
                    end
                end
            end
        end

        -- Lógica do ESP Otimizada
        if ESPEnabled then
            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character then
                    ApplyESP(player.Character, Color3.fromRGB(0, 255, 255))
                end
            end

            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid") then
                    if not Players:GetPlayerFromCharacter(obj) then
                        ApplyESP(obj, Color3.fromRGB(255, 0, 255))
                    end
                end
            end
        else
            -- Limpeza de ESP quando desligado
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj.Name == "LuposESP" then obj:Destroy() end
            end
        end
        
        RunService.Heartbeat:Wait()
    end
end)

